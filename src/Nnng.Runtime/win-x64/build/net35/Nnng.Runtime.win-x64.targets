<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Condition="'$(MSBuildThisFileFullPath)' != '' And Exists('$(MSBuildThisFileFullPath).user')"
          Project="$(MSBuildThisFileFullPath).user" />

  <PropertyGroup>
    <ShouldCopyNngNativeLib Condition="'$(ShouldCopyNngNativeLib)' == ''">True</ShouldCopyNngNativeLib>
  </PropertyGroup>

  <ItemGroup Condition="'$(MSBuildRuntimeType)' != 'Core' And '$(ShouldCopyNngNativeLib)' != 'False'">
    <NngNativeLib Include="$(MSBuildThisFileDirectory)..\..\runtimes\win-x64\native\*">
      <Dir>x64\</Dir>
    </NngNativeLib>

    <None Include="@(NngNativeLib)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>%(Dir)%(Filename)%(Extension)</Link>
      <Visible>False</Visible>
    </None>
  </ItemGroup>
</Project>
