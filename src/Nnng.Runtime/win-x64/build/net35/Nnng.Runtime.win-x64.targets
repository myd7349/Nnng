<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Condition="'$(MSBuildRuntimeType)' != 'Core' AND ('$(Platform)' == 'x64' OR '$(Platform)|$(Prefer32Bit)' == 'AnyCPU|false')">
    <NngNativeLib Include="$(MSBuildThisFileDirectory)..\..\runtimes\win-x64\native\*">
      <Dir>x64\</Dir>
    </NngNativeLib>

    <None Include="@(NngNativeLib)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>%(Dir)%(Filename)%(Extension)</Link>
      <Visible>False</Visible>
    </None>
  </ItemGroup>
</Project>
